---
import SectionHeader from './SectionHeader.astro';

interface Props {
  id: string;
  eyebrow: string;
  headingHtml: string;
  description: string;
  videoUrl: string;
  videoUrlHd?: string;
  poster?: string;
  ariaLabel: string;
}

const { id, eyebrow, headingHtml, description, videoUrl, videoUrlHd, poster, ariaLabel } = Astro.props;

// Detect remote embed (YouTube / Vimeo). Anything else is treated as a local file path.
const ytMatch = videoUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([\w-]{6,})/);
const vimeoMatch = videoUrl.match(/vimeo\.com\/(?:video\/)?(\d+)/);
let embedUrl: string | null = null;
if (ytMatch) embedUrl = `https://www.youtube-nocookie.com/embed/${ytMatch[1]}?rel=0&modestbranding=1`;
else if (vimeoMatch) embedUrl = `https://player.vimeo.com/video/${vimeoMatch[1]}?dnt=1`;
---
<section class="video-section" id={id} aria-labelledby={`${id}-heading`}>
  <SectionHeader
    eyebrow={eyebrow}
    headingHtml={headingHtml}
    lede={description}
    id={`${id}-heading`}
  />

  <div class="video-wrap">
    {embedUrl ? (
      <div class="video-embed">
        <iframe
          src={embedUrl}
          title={ariaLabel}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        ></iframe>
      </div>
    ) : (
      <video
        class="video-player"
        controls
        preload="none"
        playsinline
        poster={poster}
        aria-label={ariaLabel}
      >
        {videoUrlHd ? (
          <>
            <source src={videoUrl} type="video/mp4" media="(max-width: 900px)" />
            <source src={videoUrlHd} type="video/mp4" />
          </>
        ) : (
          <source src={videoUrl} type="video/mp4" />
        )}
        Your browser does not support HTML5 video.
        <a href={videoUrl} download>Download the file</a>.
      </video>
    )}
  </div>
</section>
