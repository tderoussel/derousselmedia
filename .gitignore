# ============================================================
#  Top-level .gitignore for the DeRoussel Media repo
# ============================================================

# Node / Astro
node_modules/
.astro/
dist/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example

# macOS / Windows / editor cruft
.DS_Store
._*
Thumbs.db
ehthumbs.db
desktop.ini
.idea/
.vscode/

# Local caches used by build tooling
.cache/
.claude/
# The original prompt that bootstrapped this work — not part of the deployable source.
OVERNIGHT_PROMPT.md

# Python (legacy build pipeline lives in scripts/)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# The legacy hand-tuned static site lives here for reference. It still works as-is
# but is replaced by cms-site/. Excluded from the git repo to keep size in check.
# Files on disk are untouched.
/site/

# Lighthouse + build reports written during local verification
/CMS_MIGRATION_assets/

# Original raw source media — never modified, not part of the deploy.
# (~400 MB combined; lives on disk for the developer, not in the repo.)
/journalism/
/landscape/
/miscellaneous/
/sports photography/
/BUILD_REPORT_assets/
